# YouTube OAuth (run youtube_auth_now.py to get refresh token)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_ENABLED=true
SKIP_YOUTUBE_UPLOAD=false
YOUTUBE_PRIVACY=public

# Pexels (free, 200 req/hour — get key at pexels.com/api)
PEXELS_API_KEY=

# LLM (Groq free tier — get key at console.groq.com)
LLM_PROVIDER=groq
GROQ_API_KEY=

# Source channel
STARDRIFT_CHANNEL_URL=https://www.youtube.com/@official_stardrift
